# ─── BridgeAI Server Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in your real values. NEVER commit .env

# PostgreSQL — NeonDB connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
VITE_API_URL=http://localhost:5001
VITE_POLLINATIONS_API_KEY=your_pollinations_api_key_here

# Pollinations AI key (get from pollinations.ai)
POLLINATIONS_API_KEY=your_pollinations_api_key_here

# JWT secret — use any long random string
JWT_SECRET=your_long_random_secret_here

# Server port (local dev only — ignored on Vercel)
PORT=5001

# Environment
NODE_ENV=development

# SMTP Configuration (for emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="BridgeAI" <no-reply@bridgeai.com>
